# Dev: dùng Vite proxy /api -> http://localhost:8080 (tránh lỗi CORS giữa 5173 và 8080)
# Nếu muốn gọi thẳng 8080: VITE_API_BASE=http://localhost:8080/api (cần backend CORS + restart)
VITE_API_BASE=/api
VITE_UPLOAD_BASE=/api

# Google Login (thật - không demo)
# 1. Lấy Client ID từ Google Cloud Console (phải giống hệt giá trị google.client-id ở backend)
# 2. Thêm http://localhost:5173 vào Authorized JavaScript origins của Client ID đó
# 3. Thay dòng dưới bằng Client ID thật của bạn
# 4. QUAN TRỌNG: Sau khi sửa file này phải dừng frontend (Ctrl+C) và chạy lại "npm run dev"
VITE_GOOGLE_CLIENT_ID=570995586789-ov9e0j7p694o52rsb509qaemgh8gc8eg.apps.googleusercontent.com